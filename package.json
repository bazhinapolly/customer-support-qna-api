{
  "name": "customer-support-qna-api",
  "version": "2.0.0",
  "private": true,
  "description": "Authenticated OpenAI-backed customer support Q&A REST API.",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "test": "node --test",
    "test:coverage": "c8 --check-coverage --branches 85 --functions 90 --lines 90 --statements 90 node --test",
    "check": "node --check src/*.js scripts/*.mjs && node scripts/check-openapi.mjs && node scripts/evaluate.mjs --validate && npm run test:coverage",
    "eval:openai": "node scripts/evaluate.mjs"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "openai": "^6.47.0"
  },
  "devDependencies": {
    "c8": "10.1.3"
  }
}
